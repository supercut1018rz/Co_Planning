# =======================================
# Howard County Sidewalk Planning System
# Environment variables example
# =======================================
# Usage:
#   cp .env.example .env
#   Then edit .env with your real keys

# =======================================
# OpenAI API
# =======================================
OPENAI_API_KEY=replace_me_with_your_openai_api_key
OPENAI_BASE_URL=https://us.api.openai.com/v1
OPENAI_MODEL=gpt-4o

# =======================================
# Mapillary API
# =======================================
MAPILLARY_CLIENT_TOKEN=replace_me_with_your_mapillary_token

# =======================================
# Database
# =======================================
# Docker deployment (from inside container):
# DATABASE_URL=postgresql://appuser:ChangeMe_StrongPW@db:5432/howard_sidewalk_db

# Development or local access to Docker DB:
DATABASE_NAME=howard_sidewalk_db
DATABASE_USER=appuser
DATABASE_PASSWORD=ChangeMe_StrongPW
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432  # Use 5432 for local dev; use 5433 when connecting to Docker DB

# Connection pool
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONN_TIMEOUT_MS=5000
